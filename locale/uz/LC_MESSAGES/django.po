msgid "Current language:"
msgstr "Joriy til:"

msgid "Language changed to"
msgstr "Til o'zgartirildi:"

msgid "🇺🇸 English"
msgstr "🇺🇸 Ingliz"

msgid "🇷🇺 Русский"
msgstr "🇷🇺 Rus"

